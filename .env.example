# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Database (Neon Postgres)
DATABASE_URL=postgresql://<user>:<password>@<host>/<db>?sslmode=require

# Supabase Auth
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_ANON_KEY=<supabase-anon-key>
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<supabase-anon-key>

# AI providers
REPLICATE_API_TOKEN=<replicate-api-token>
QWENPLUS_API_KEY=<qwenplus-api-key>
DASHSCOPE_API_KEY=<dashscope-api-key>
DEEPSEEK_API_KEY=<deepseek-api-key>

# Shared R2 endpoint (S3 compatible)
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# R2 object storage - image bucket
R2_BUCKET_NAME_IMG=recipe-images
R2_ACCESS_KEY_ID_IMG=<r2-access-key-id>
R2_SECRET_ACCESS_KEY_IMG=<r2-secret-access-key>
R2_PUBLIC_URL_IMG=https://<your-r2-image-public-domain>
NEXT_PUBLIC_R2_PUBLIC_URL_IMG=https://<your-r2-image-public-domain>

# R2 object storage - docs bucket (public docs domain)
R2_BUCKET_NAME_DOC=recipe-doc
R2_ACCESS_KEY_ID_DOC=<r2-access-key-id>
R2_SECRET_ACCESS_KEY_DOC=<r2-secret-access-key>
R2_PUBLIC_URL_DOC=https://<your-r2-doc-public-domain>
NEXT_PUBLIC_R2_PUBLIC_URL_DOC=https://<your-r2-doc-public-domain>

# Optional analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# PayPal (credit purchase)
# sandbox | live
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=<paypal-client-id>
PAYPAL_CLIENT_SECRET=<paypal-client-secret>
PAYPAL_WEBHOOK_ID=<paypal-webhook-id>
